@using PokeBlaz.Services
@inject AuthService AuthService
@inject NavigationManager Navigation
@rendermode InteractiveServer
@implements IDisposable

@* Menu de navigation présent sur toutes les pages.
   Affiche des liens différents selon l'état d'authentification
   (géré par AuthService). S'abonne aux changements d'auth pour
   forcer le rafraîchissement du composant. *@

<nav class="navbar">
    <a href="/"> Accueil</a>
    <a href="/pokemon"> Pokémons</a>

    @if (AuthService.EstConnecte)
    {
        <a href="/favoris"> Mes Favoris</a>
        <a href="/build"> Mon Build</a>
        <span> @AuthService.NomUtilisateur</span>
        <button @onclick="SeDeconnecter">Déconnexion</button>
    }
    else
    {
        <a href="/login"> Connexion</a>
    }
</nav>

@code {
    protected override void OnInitialized()
    {
        // S'abonne aux changements d'authentification pour rafraîchir
        // la navigation (affichage des liens / nom utilisateur)
        AuthService.OnAuthChanged += RefreshNav;
    }

    private void RefreshNav()
    {
        InvokeAsync(StateHasChanged);
    }

    private void SeDeconnecter()
    {
        AuthService.Deconnecter();
        Navigation.NavigateTo("/");
    }

    public void Dispose()
    {
        // Désabonne proprement lors de la destruction du composant
        AuthService.OnAuthChanged -= RefreshNav;
    }
}