@page "/login"
@using PokeBlaz.Services
@inject AuthService AuthService
@inject NavigationManager Navigation
@rendermode InteractiveServer

@* Page de connexion simple :
   - Utilise AuthService pour valider les identifiants
   - Redirige vers la page des favoris en cas de succès
*@

<div class="login-container">
    <h1> Connexion</h1>

    @if (erreur)
    {
        <p class="erreur">Nom d'utilisateur ou mot de passe incorrect.</p>
    }

    <div class="login-form">
        <input type="text" placeholder="Nom d'utilisateur"
               @bind="nom" />
        <input type="password" placeholder="Mot de passe"
               @bind="motDePasse" />
        <button @onclick="SeConnecter">Se connecter</button>
    </div>

    <p class="hint">Comptes disponibles : ash / pikachu — misty / togepi</p>
</div>

@code {
    // Champs liés aux inputs du formulaire
    private string nom = "";
    private string motDePasse = "";
    // Indique si une erreur de connexion doit être affichée
    private bool erreur = false;

    // Tente la connexion en utilisant AuthService. En cas de succès,
    // redirige l'utilisateur vers /favoris, sinon active le flag d'erreur.
    private void SeConnecter()
    {
        erreur = false;
        if (AuthService.Connecter(nom, motDePasse))
            Navigation.NavigateTo("/favoris");
        else
            erreur = true;
    }
}